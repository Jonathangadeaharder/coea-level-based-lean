# MathProver tooling (clone https://github.com/VidiomTM/mathprover separately)
MATHPROVER_HOME=/path/to/mathprover

# Default Lean project for the MathProver UI picker
MATHPROVER_PROJECT_PATH=/path/to/lean-runtime-analysis

# Optional: colon-separated roots allowed in the project picker
# MATHPROVER_ALLOWED_ROOTS=$HOME/projects:$HOME/Documents/projects

# Goedel local prover (required for leaf dispatch)
GOEDEL_PROVER_PATH=/path/to/goedel-prover-v2-32b/run.sh

# Aristotle cloud prover (required for capstone / escalation)
# ARISTOTLE_API_KEY=
